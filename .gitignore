.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Virtualenvs
.venv/
venv/
env/
ENV/

# Editors
.idea/
.vscode/
*.swp
*~
.DS_Store

# Hydra / outputs
outputs/
.hydra/
multirun/

# Model artefacts (never commit weights, PDBs, datasets)
*.pdb
*.cif
*.mmcif
*.pt
*.ckpt
*.safetensors
*.npz
checkpoints/
data/

# Frontend (M5)
node_modules/
.svelte-kit/
src/parafold/viz_api/static/

# Failure recovery sandbox. Everything under experiments/_wip/ is local-only
# scratch (R8 protocol: cp -r snapshots of failed work-trees, never commit).
# The keep-file below is the one allowed tracked entry.
experiments/_wip/*
!experiments/_wip/.gitkeep
!experiments/_wip/README.md

# Secrets — never commit env files
.env
.env.*
!.env.example
